# -----------------------------
# NODE MODULES
# -----------------------------
node_modules/
**/node_modules/

# -----------------------------
# ENV FILES (VERY IMPORTANT)
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# LOG FILES
# -----------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# -----------------------------
# BUILD / DIST
# -----------------------------
dist/
build/
out/
.next/
.vite/

# -----------------------------
# VITE / FRONTEND CACHE
# -----------------------------
node_modules/.vite/
*.local

# -----------------------------
# OS FILES
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# IDE / EDITOR
# -----------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------
# PRISMA (IMPORTANT)
# -----------------------------
# NEVER commit generated client if using local builds
node_modules/.prisma/

# Optional (if you ever generate client outside node_modules)
prisma/generated/

# -----------------------------
# DATABASE FILES (if any local)
# -----------------------------
*.sqlite
*.db

# -----------------------------
# TEST / COVERAGE
# -----------------------------
coverage/
.nyc_output/

# -----------------------------
# TEMP FILES
# -----------------------------
tmp/
temp/

# -----------------------------
# SECRETS / KEYS
# -----------------------------
*.pem
*.key
*.crt

# -----------------------------
# MISC
# -----------------------------
*.tsbuildinfo